:"widget"},{"id":"34baaead","settings":{"image":{"url":"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2024\/09\/Betty-A-Headshot.png","id":87347,"size":"","alt":"","source":"library"},"image_size":"medium","_element_width":"initial","_element_custom_width":{"unit":"%","size":94.458},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"image","elType":"widget"},{"id":"1c2e62de","settings":{"editor":"<p>Operations &amp; Finance Leader<\/p>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":20,"sizes":[]},"_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":"","elType":"column"},{"id":"2272072f","settings":{"_column_size":50,"space_between_widgets":0,"border_border":"solid","border_width":{"unit":"px","top":"0","right":"0","bottom":"1","left":"0","isLinked":""},"padding":{"unit":"%","top":"5","right":"5","bottom":"5","left":"5","isLinked":"1"},"_inline_size_tablet":"100","padding_tablet":{"unit":"%","top":"5","right":"5","bottom":"5","left":"5","isLinked":"1"},"padding_mobile":{"unit":"%","top":"10","right":"10","bottom":"10","left":"10","isLinked":"1"},"__globals__":{"border_color":""},"border_color":"#5659C7","pa_condition_repeater":[],"_inline_size":70,"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","content_position":"center"},"elements":[{"id":"296dc3f6","settings":{"editor":"<div class=\"TypographyPresentation TypographyPresentation--medium RichText3-paragraph--withVSpacingNormal RichText3-paragraph HighlightSol HighlightSol--buildingBlock\">Betty Arellano is the Chief Operating Officer of the Engineering Management Institute (EMI), overseeing Finance, Human Resources, Operations, and Learning &amp; Development. She leads a dynamic team of project managers, designers, and delivery specialists to design, implement, and evaluate innovative programs that drive organizational growth \u2014 managing multiple initiatives simultaneously while keeping each one on time, within scope, and on budget.<\/div><div>\u00a0<\/div><div class=\"TypographyPresentation TypographyPresentation--medium RichText3-paragraph--withVSpacingNormal RichText3-paragraph HighlightSol HighlightSol--buildingBlock\">Betty's path to operations leadership is rooted in a strong technical foundation. She earned her Bachelor's degree in Chemical Engineering from De La Salle University Philippines and her Master's degree in Chemical Engineering from the University of the Philippines (UP). After graduating, she co-founded a consulting firm with fellow UP alumni, helping companies navigate environmental compliance, permitting requirements, and impact assessments.<\/div><div class=\"TypographyPresentation TypographyPresentation--medium RichText3-paragraph--withVSpacingNormal RichText3-paragraph HighlightSol HighlightSol--buildingBlock\">She was selected as one of the Philippine representatives for a 10-month Industrial Biotechnology and Technology Transfer program in Germany, which deepened her global perspective on engineering and innovation. She also played a pivotal role in launching a startup, serving as management representative for ISO 9000\/14000 quality, environmental, health, and safety management systems.<\/div><div class=\"TypographyPresentation TypographyPresentation--medium RichText3-paragraph--withVSpacingNormal RichText3-paragraph HighlightSol HighlightSol--buildingBlock\">Betty relocated to the United States in 2006 and joined the EMI team in 2012, where she has spent over a decade channeling her engineering discipline and global experience into building programs that develop the next generation of engineering leaders.<\/div><div class=\"TypographyPresentation TypographyPresentation--medium RichText3-paragraph--withVSpacingNormal RichText3-paragraph HighlightSol HighlightSol--buildingBlock\">\u00a0<\/div>","typography_typography":"custom","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","typography_font_size":{"unit":"px","size":18,"sizes":[]}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":"","elType":"section"}],"settings":{"width":{"unit":"px","size":1000,"sizes":[]},"entrance_animation":"fadeIn","exit_animation":"fadeIn","entrance_animation_duration":{"unit":"px","size":"0.5","sizes":[]},"overlay_background_color":"#FFFAF5CC","close_button_color":"#0F1319","close_button_hover_color":"#5659C7","width_tablet":{"unit":"px","size":"720","sizes":[]},"__globals__":{"overlay_background_color":"","close_button_color":"","close_button_hover_color":""}},"metadata":{"disable_sitewide_popup":""},"display_settings":{"triggers":{"click":"yes","click_times":1},"timing":{"devices":"yes","devices_devices":["desktop","mobile","mobile_extra","tablet","tablet_extra","laptop","widescreen"]}}}