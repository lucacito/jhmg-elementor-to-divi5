try Officer, he led platoon- and company-size units on ship-borne and land-based deployments across Australia, Asia, Africa, and the Pacific and Indian Oceans.<\/span><\/p><p><span style=\"font-weight: 400;\">After earning his B.S. in Civil Engineering, Carter transitioned to the steel industry, where he honed his ability to align team and organizational goals to drive profitable outcomes. In 2021, he joined Talent Matters, leveraging predictive analytics, coaching, and leadership development to help companies select, develop, and retain top talent. In 2024, Talent Matters partnered with EMI to launch the AEC PM Behaviors Assessment.<\/span><\/p>","typography_typography":"custom","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","typography_font_size":{"unit":"px","size":18,"sizes":[]}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":"","elType":"section"}],"settings":{"width":{"unit":"px","size":1000,"sizes":[]},"entrance_animation":"fadeIn","exit_animation":"fadeIn","entrance_animation_duration":{"unit":"px","size":"0.5","sizes":[]},"overlay_background_color":"#FFFAF5CC","close_button_color":"#0F1319","close_button_hover_color":"#5659C7","width_tablet":{"unit":"px","size":"720","sizes":[]},"__globals__":{"overlay_background_color":"","close_button_color":"","close_button_hover_color":""}},"metadata":{"disable_sitewide_popup":""},"display_settings":{"triggers":{"click":"yes","click_times":1},"timing":{"devices":"yes","devices_devices":["desktop","mobile","mobile_extra","tablet","tablet_extra","laptop","widescreen"]}}}