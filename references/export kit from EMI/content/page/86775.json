":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"76c74cbd","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"50c802b1","settings":{"editor":"<p>Across the architecture, engineering, and construction (AEC) industry, project managers are the engine behind client satisfaction, quality delivery, and profitability. Yet many PMs are stretched so thin that true development\u2014both technical and interpersonal\u2014falls to the bottom of the priority list. What happens when you create space for them to learn with and from one another?<\/p><p>In this webinar, we take you inside the Engineering Management Institute\u2019s second annual <strong>AEC PM Connect<\/strong> event\u2014where more than 60 AEC project managers and PM development leaders came together for a full day of collaboration, shared learning, and practical strategies for strengthening project delivery at scale.<\/p><p>Whether you lead project managers, run PM training programs, or are looking to elevate PM performance across your firm, this session will give you evidence-based insights and industry-tested approaches you can apply immediately.<\/p><p><strong>What You\u2019ll Learn<\/strong><\/p><p>In this session, we\u2019ll explore the most impactful themes that emerged across 20 sessions and five interactive tracks at AEC PM Connect, including:<\/p><ul><li>Building a Scalable PM Development Framework<\/li><li>Addressing the PM Skills Gap<\/li><li>Modernizing Project Delivery Through Effective Tools &amp; Processes<\/li><li>Strengthening PM Retention &amp; Engagement<\/li><li>The Power of Collaboration &amp; Collective Intelligence<\/li><\/ul><p><!-- \/wp:fl-builder\/layout --><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"255b8be9","settings":{"editor":"<p class=\"fl-heading\"><b>Speaker<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"36a3a6b5","settings":{"editor":"<h2 class=\"fl-heading\"><b>Anthony Fasano, P.E., AEC PM | Engineering Management Institute<\/b><\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2b70cb71","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"alignright wp-image-55130\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a><\/p><p>Most AEC organizations are too busy to focus on attracting, developing, and retaining talented professionals, making it hard to grow. Through his work a tEMI, Fasano utilizes a proven framework to help organizations, both public and private, build professional development plans, programs, and tools that help them attract, build, AND maintain strong teams and grow sustainably.<\/p><p>Fasano has written a bestselling book entitled\u00a0<b><i>Engineer Your Own Success\u00a0<\/i><\/b><i>(by IEEE-Wiley Press)<\/i>, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"2","_yoast_wpseo_content_score":"90","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}