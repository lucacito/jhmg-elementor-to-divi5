them attract, build, AND maintain strong teams and grow sustainably.<\/span><\/p><p><span style=\"font-weight: 400;\">Fasano has written a bestselling book entitled <\/span><b><i>Engineer Your Own Success <\/i><\/b><i><span style=\"font-weight: 400;\">(by IEEE-Wiley Press)<\/span><\/i><span style=\"font-weight: 400;\">, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/span><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_content_score":"90","be_title_toggle_hide":"1","_yoast_wpseo_estimated-reading-time-minutes":"2","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}