":33,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"2e0a19df","settings":{"video_type":"vimeo","youtube_url":"https:\/\/www.youtube.com\/watch?v=XHOmBV4js_E","vimeo_url":"https:\/\/vimeo.com\/1198793727","dailymotion_url":"https:\/\/www.dailymotion.com\/video\/x6tqhqb","videopress_url":"https:\/\/videopress.com\/v\/ZCAOzTNk","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","yt_privacy":"yes","vimeo_title":"","vimeo_portrait":"","vimeo_byline":""},"elements":[],"isInner":false,"widgetType":"video","elType":"widget"},{"id":"c596bb0","settings":{"editor":"<p><span style=\"color: #ffffff;\"><a style=\"color: #ffffff;\" href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2026\/06\/VHB-EV-Primer-Slides.pdf\" target=\"_blank\" rel=\"noopener\">Click Here to Download the Slides<\/a><\/span><\/p>","align":"center","text_color":"#FFFFFF","_padding":{"unit":"px","top":"20","right":"20","bottom":"20","left":"20","isLinked":true},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"},{"id":"4e8324b7","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[],"margin":{"unit":"px","top":"40","right":0,"bottom":"40","left":0,"isLinked":false}},"elements":[{"id":"1f2364a4","settings":{"_column_size":100,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"1c6c64c5","settings":{"editor":"<p>Earned Value Management (EVM) is a powerful project management approach that helps AEC professionals measure project performance by integrating scope, schedule, and budget into a single framework. Unlike traditional methods that compare planned budgets to actual costs, EVM provides deeper insight by evaluating how much work has actually been completed relative to what was planned. This enables project managers to identify performance issues early, make informed decisions, and take corrective action before small problems become major project challenges.<\/p><p>Many AEC projects experience budget overruns and schedule delays because progress is often measured using subjective estimates, hours spent, or revenue generated rather than actual scope completion. Earned Value Management addresses these challenges by providing objective performance metrics that reveal whether a project is truly on track. By using tools such as Cost Performance Index (CPI), Schedule Performance Index (SPI), Estimate at Completion (EAC), and Estimate to Complete (ETC), project managers can better understand project health, forecast future outcomes, and proactively manage risks.<\/p><p>In this session, participants will:<\/p><ul><li>Learn the core principles of Earned Value Management, including Planned Value (PV), Earned Value (EV), and Actual Cost (AC).<\/li><li>Discover how to measure cost and schedule performance using CPI and SPI to identify potential project issues early.<\/li><li>Explore forecasting techniques, including Estimate at Completion (EAC) and Estimate to Complete (ETC), to predict project outcomes and support proactive decision-making.<\/li><\/ul><p>\u00a0<\/p><p style=\"text-align: center;\"><strong>*PDH Credits will be processed during the week of\u00a0<\/strong><strong>June 15th<\/strong><strong>. Please\u00a0<a href=\"https:\/\/www.surveymonkey.com\/r\/VHBWebinarEV060426\" target=\"_blank\" rel=\"noopener noreferrer\">complete the survey<\/a>\u00a0by then to qualify for PDH credits.<\/strong><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas","hide_title":"yes"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"2","_yoast_wpseo_content_score":"60","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1","hpt_headertitle":"on","sps_website":"a:1:{i:0;s:43:\"https:\/\/engineeringmanagementinstitute.org\/\";}"}}