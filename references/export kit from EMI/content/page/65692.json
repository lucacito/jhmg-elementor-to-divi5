ooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"},{"id":"1bc0ccbd","settings":{"_column_size":50,"_inline_size":null,"space_between_widgets":0,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"39761af3","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"1c5af17e","settings":{"editor":"<p>In the dynamic and fast-paced Architecture, Engineering, and Construction (AEC) industry, the effective allocation and management of resources is crucial for the success of any project. Proper resource loading ensures that projects stay on time, on budget, and meet quality standards, while minimizing risks and maximizing productivity. It is also important for maintaining the right number of staff.<\/p>\n<p>Join us for this insightful webinar where we delve into the key principles and best practices of resource loading in AEC projects. This session will equip you with the examples of tools and strategies to streamline resource management, optimize workflows, and avoid common pitfalls that can lead to project delays and cost overruns.<\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"3e12cfd6","settings":{"editor":"<p><strong>Learning Objectives:<\/strong><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"187f38c3","settings":{"editor":"<ul>\n<li>Understand the fundamentals of resource loading and its importance in AEC projects.<\/li>\n<li>Explore techniques for balancing resources across multiple projects.<\/li>\n<li>Learn how to utilize software tools for effective resource tracking and forecasting.<\/li>\n<li>Discover strategies for dealing with resource shortages and bottlenecks.<\/li>\n<li>Gain insights into real-world case studies showcasing successful resource loading.<\/li>\n<li>Best practices for collaboration between design, engineering, and construction teams.<\/li>\n<\/ul>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"4773bc08","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Speaker<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"57ef9932","settings":{"editor":"<h2 class=\"fl-heading\"><em><span class=\"fl-heading-text\">Anthony Fasano, PE<\/span><\/em><\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"701feb67","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"wp-image-55130 size-medium alignright\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano-300x300.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a>Anthony Fasano, PE, is the President &amp; CEO - of the Engineering Management Institute, a company focused on helping engineers become better leaders. He is the author of Engineer Your Own Success: 7 Key Elements to Creating an Extraordinary Engineering Career.<\/p>\n<p>Anthony received a B.S. and a M.S. in Civil Engineering from Lafayette College and Columbia University, respectively, and his coaching certificate from the Institute of Professional Excellence in Coaching. He is a licensed Professional Engineer and a TEDx Speaker. Anthony lives in New Jersey with his wife, Jill, and their three children.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_content_score":"90","be_title_toggle_hide":"1","_yoast_wpseo_estimated-reading-time-minutes":"2","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":""}}