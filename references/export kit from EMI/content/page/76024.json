nit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"4d9fcf","settings":{"text":"Divider","color":"#E7A60E","weight":{"unit":"px","size":3,"sizes":[]},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"divider","elType":"widget"},{"id":"1a13bc01","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"34f85836","settings":{"editor":"<p><span style=\"font-weight: 400;\"><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/02\/1668516511343.png\"><img class=\"alignright wp-image-72877\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/02\/1668516511343.png\" alt=\"\" width=\"500\" height=\"262\"><\/a>Are your project managers stuck in the \"one-and-done\" training cycle? Traditional project management (PM) bootcamps often fail to deliver long-term value, leaving PMs overwhelmed, unsupported, and struggling to implement what they\u2019ve learned. Join us for a transformative webinar that will teach you how to shift from ineffective PM training events to cultivating a sustainable, PM-oriented culture within your architecture and engineering (AE) consulting firm.<\/span><\/p>\n<h3><b>What You\u2019ll Learn:<\/b><\/h3>\n<ol>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><b>Why Traditional PM Training Falls Short<\/b><b><br><\/b><span style=\"font-weight: 400;\"> Understand the common pitfalls of one-off training programs and how they fail to provide long-term ROI for your firm or PMs.<\/span><\/li>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><b>The Importance of a PM Culture<\/b><b><br><\/b><span style=\"font-weight: 400;\"> Learn why project management is a mindset and how fostering an ongoing PM-oriented culture boosts project consistency, client satisfaction, and profitability.<\/span><\/li>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><b>How to Build a Customized PM Development Program<\/b><b><br><\/b><span style=\"font-weight: 400;\"> Discover the benefits of tailoring PM training to fit your firm\u2019s unique processes, terminology, and challenges, and how to integrate consistent training activities and transfer events to reinforce learning.<\/span><\/li>\n<\/ol>\n<h3><b>Who Should Attend?<\/b><\/h3>\n<p><span style=\"font-weight: 400;\">This webinar is designed for AE firm leaders who want to increase project profitability, retain top talent, and establish project management as a core organizational strength. You\u2019ll walk away with actionable strategies to:<\/span><\/p>\n<ul>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><span style=\"font-weight: 400;\">Create consistency across your organization.<\/span><\/li>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><span style=\"font-weight: 400;\">Facilitate meaningful learning opportunities for your PMs.<\/span><\/li>\n<li style=\"font-weight: 400;\" aria-level=\"1\"><span style=\"font-weight: 400;\">Build a PM development program with a high return on investment.<\/span><\/li><\/ul>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"4ae998fb","settings":{"editor":"<p class=\"fl-heading\"><b>Your Presenter<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"508f27e5","settings":{"editor":"<h2 class=\"fl-heading\"><b>Anthony Fasano, P.E., AEC PM | Engineering Management Institute<\/b><\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2bcb9208","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"alignright wp-image-55130 size-medium\" title=\"Anthony Fasano, P.E., AEC PM\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano-300x300.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a><\/p><p><span style=\"font-weight: 400;\">Most AEC organizations are too busy to focus on attracting, developing, and retaining talented professionals, making it hard to grow. Through his work a tEMI, Fasano utilizes a proven framework to help organizations, both public and private, build professional development plans, programs, and tools that help them attract, build, AND maintain strong teams and grow sustainably.<\/span><\/p><p><span style=\"font-weight: 400;\">Fasano has written a bestselling book entitled <\/span><b><i>Engineer Your Own Success <\/i><\/b><i><span style=\"font-weight: 400;\">(by IEEE-Wiley Press)<\/span><\/i><span style=\"font-weight: 400;\">, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/span><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_content_score":"30","be_title_toggle_hide":"1","_yoast_wpseo_estimated-reading-time-minutes":"3","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}