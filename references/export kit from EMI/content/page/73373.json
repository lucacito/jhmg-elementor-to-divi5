{"content":[{"id":"271c5071","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[]},"elements":[{"id":"328a93a1","settings":{"_column_size":100,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"3dee5f8f","settings":{"editor":"<h1>Visit EMI at the AEC HR Summit to Learn How You Can<br \/>Recruit, Develop, and Retain Top AEC Professionals<\/h1>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":35,"sizes":[]},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"31dd0357","settings":{"image":{"url":"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/03\/Image-1-EMI-1.jpg","id":73788,"size":"","alt":"AEC HR Summit","source":"library"},"image_size":"custom","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","image_custom_dimension":{"width":"600","height":""}},"elements":[],"isInner":false,"widgetType":"image","elType":"widget"},{"id":"4f0bcf7e","settings":{"editor":"<p>Take a minute now to book a meeting with us at the event to ensure you have a productive sumit.<\/p>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":22,"sizes":[]},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"38406159","settings":{"anchor":"connect","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"menu-anchor","elType":"widget"},{"id":"4f578de9","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[],"background_background":"classic","background_color":"#D9DADE"},"elements":[{"id":"4e8f87cc","settings":{"_column_size":100,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"7591946b","settings":{"shortcode":"[convertkit form=7793206]","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_padding":{"unit":"px","top":"20","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"shortcode","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"4e018dde","settings":{"editor":"<p>The Engineering Management Institute (EMI) is attending the <strong data-start=\"465\" data-end=\"509\">AEC HR Summit, April 9-11 in Phoenix, AZ<\/strong>, and we\u2019d love to connect with you on developing your people, strengthening your teams, and driving lasting success.<\/p>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":25,"sizes":[]},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_padding":{"unit":"px","top":"20","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"595d9502","settings":{"editor":"<p data-start=\"641\" data-end=\"903\">The <a href=\"https:\/\/employeeengagement.com\/aechrsummit\/\" target=\"_blank\" rel=\"noopener\"><strong data-start=\"645\" data-end=\"662\">AEC HR Summit<\/strong><\/a> is the industry\u2019s leading event focused entirely on the people side of the AEC industry. If you\u2019re looking for fresh ideas, innovative strategies, and proven solutions for your firm\u2019s biggest workforce challenges, this is the place to be.<\/p><p data-start=\"905\" data-end=\"1190\">With an agenda designed to tackle critical topics like <strong data-start=\"960\" data-end=\"989\">recruitment and retention<\/strong>, <strong data-start=\"991\" data-end=\"1017\">leadership development<\/strong>, <strong data-start=\"1019\" data-end=\"1026\">DEI<\/strong>, and <strong data-start=\"1032\" data-end=\"1052\">culture building<\/strong>, this summit brings together the industry\u2019s top HR, talent, and operations leaders to share insights and collaborate on real solutions.<\/p><p data-start=\"1192\" data-end=\"1338\"><b>At EMI, our mission is simple:<\/b><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"14f26d8e","settings":{"editor":"<p data-start=\"1192\" data-end=\"1338\"><i><u>We help AEC professionals become better leaders, communicators, and project managers so their firms can thrive.<\/u><\/i><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":25,"sizes":[]},"typography_font_weight":"600","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"6372c437","settings":{"editor":"<p data-start=\"1340\" data-end=\"1560\">And that\u2019s why we\u2019re excited to be part of this year\u2019s summit. We want to meet with firms who are passionate about investing in their people and creating workplaces where technical professionals can do their best work.<\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"f24bfe9","settings":{"title":"How EMI Supports People-Driven AEC Firms:","header_size":"h3","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"title_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"heading","elType":"widget"},{"id":"117505c8","settings":{"editor":"<p data-start=\"1611\" data-end=\"1895\"><strong data-start=\"1611\" data-end=\"1656\">AEC PM Certification<\/strong><br data-start=\"1656\" data-end=\"1659\">Designed specifically for the AEC industry, our certification program provides project managers with the tools, processes, and confidence they need to successfully lead projects while supporting business goals and client satisfaction.<\/p>\n<p data-start=\"1897\" data-end=\"2135\"><strong data-start=\"1897\" data-end=\"1923\">People Skills Training<\/strong><br data-start=\"1923\" data-end=\"1926\">From communication and collaboration to time management and client interactions, we help technical professionals build the essential soft skills they need to work better together and deliver better outcomes.<\/p>\n<p data-start=\"2137\" data-end=\"2403\"><strong data-start=\"2137\" data-end=\"2170\">Leadership Skills Development<\/strong><br data-start=\"2170\" data-end=\"2173\">We train professionals at all levels to become effective, empathetic leaders\u2014whether they\u2019re managing a team of two or twenty. Our programs focus on practical leadership strategies tailored to the unique challenges of AEC firms.<\/p>\n<p data-start=\"2405\" data-end=\"2642\"><strong data-start=\"2405\" data-end=\"2425\">Keynote Speaking<\/strong><br data-start=\"2425\" data-end=\"2428\">Looking to inspire your team? EMI\u2019s leadership regularly speaks at AEC conferences and internal firm events, sharing actionable insights on leadership, people development, project management, and industry trends.<\/p>\n<p data-start=\"2644\" data-end=\"2947\"><strong data-start=\"2644\" data-end=\"2673\">Industry Content Channels<\/strong><br data-start=\"2673\" data-end=\"2676\">Through our suite of AEC-focused podcasts, videos, and articles, we share real-world stories and expertise from professionals across the industry. We\u2019d love to explore how we can help share your firm\u2019s innovative people strategies and success stories with our extensive audience.<\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"530b6c0d","settings":{"title":"Why Meet with EMI at the AEC HR Summit?","header_size":"h3","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"title_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"heading","elType":"widget"},{"id":"1f616111","settings":{"editor":"<p data-start=\"3001\" data-end=\"3155\">Because we\u2019re all working toward the same goal: <strong data-start=\"3049\" data-end=\"3153\">building stronger teams, developing better leaders, and creating sustainable success through people.<\/strong><\/p><p data-start=\"3157\" data-end=\"3185\">Whether you\u2019re looking to:<\/p><ul data-start=\"3187\" data-end=\"3439\"><li data-start=\"3187\" data-end=\"3237\">Elevate your firm\u2019s internal training programs<\/li><li data-start=\"3238\" data-end=\"3300\">Improve retention through career development opportunities<\/li><li data-start=\"3301\" data-end=\"3379\">Equip your managers with stronger leadership and project management skills<\/li><li data-start=\"3380\" data-end=\"3439\">Share your success story with the broader AEC community<\/li><\/ul>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"7661f148","settings":{"editor":"<p>We\u2019re excited to learn from you, collaborate, and explore ways to support your people development strategy moving forward.<\/p>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":24,"sizes":[]},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"56aaada3","settings":{"editor":"<p data-start=\"3830\" data-end=\"3908\"><strong>The future of the AEC industry depends on how we invest in our people today.<\/strong><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":25,"sizes":[]},"typography_font_weight":"600","typography_text_transform":"capitalize","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2547585a","settings":{"editor":"<p data-start=\"3910\" data-end=\"4106\">Join us in Phoenix, April 9-11, at the AEC HR Summit, and let\u2019s start a conversation about how we can build better leaders, stronger teams, and healthier, more successful organizations together.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","align":"center","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"654b694d","settings":{"editor":"<p data-start=\"3830\" data-end=\"3908\">We can\u2019t wait to meet you there!<\/p>","align":"center","typography_typography":"custom","typography_font_size":{"unit":"px","size":35,"sizes":[]},"typography_font_weight":"600","_margin":{"unit":"px","top":"0","right":"0","bottom":"100","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"},"typography_font_style":"italic"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"default","hide_title":"yes"},"metadata":{"disable_sitewide_popup":"","_yoast_wpseo_focuskw":"AEC HR Summit","_yoast_wpseo_linkdex":"63","_yoast_wpseo_estimated-reading-time-minutes":"3","_yoast_wpseo_content_score":"60","_yoast_wpseo_metadesc":"Join us at the AEC HR Summit in Phoenix to discuss developing talent, strengthening teams, and driving lasting success!"}}