tip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"56981926","settings":{"image":{"url":"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/07\/Factor-Logo.jpg","id":79314,"size":"","alt":"Factor A\/E","source":"library"},"link_to":"custom","link":{"url":"https:\/\/factorapp.com\/","is_external":"on","nofollow":"","custom_attributes":""},"align":"left","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","image_size":"custom","image_custom_dimension":{"width":"250","height":""}},"elements":[],"isInner":false,"widgetType":"image","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"4c21922e","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"5659bdc1","settings":{"editor":"<p>Engineering teams often face project delays, resource bottlenecks, and reactive workflows that jeopardize technical quality and schedule compliance. This session presents a structured, engineering-focused approach to proactive project planning and workload forecasting.<\/p>\n<p>Join Factor A\/E, trusted experts in architecture and engineering project delivery since 1999, as they introduce proven technical planning tools such as rolling forecasts, phased delivery schedules, backlog prioritization, and resource planning. The session emphasizes how these tools can be applied to address common engineering project challenges, including design iteration cycles, review delays, and variable technical workloads.<\/p>\n<p><!-- \/wp:fl-builder\/layout --><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"},{"id":"e72c540","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[]},"elements":[{"id":"4b22df6b","settings":{"_column_size":100,"padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"30bc9795","settings":{"editor":"<!-- wp:fl-builder\/layout -->\n<h3>By the end of this session, participants will be able to:<\/h3>\n<ul>\n<li>Forecast project and utilization needsby comparing project backlogs to utilization targets.<\/li>\n<li>Establish consistent planning practices using tools that align budget, timeline, and scope to create consistent baselines for your projects.<\/li>\n<li>Balance project backlog and team capacity by creating resource plans that achieve project success and maximize utilization.<\/li>\n<li>Follow a structure for tracking and responding using clear expectations and actuals to measure against your baseline and respond accordingly.<\/li>\n<li>Develop proactive strategies to maintain schedule predictability and project delivery standards in the face of shifting project demands.<\/li>\n<\/ul>\n<!-- \/wp:fl-builder\/layout -->","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"3b49e700","settings":{"editor":"<p class=\"fl-heading\">Speaker<\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"3013318d","settings":{"editor":"<h2 class=\"fl-heading\">C. Ray Harvey<\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"42fc33bb","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/07\/C.-Ray-Harvey.jpg\"><img class=\"alignright wp-image-79315 size-medium\" title=\"C. Ray Harvey\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/07\/C.-Ray-Harvey-300x300.jpg\" alt=\"Factor A\/E\" width=\"300\" height=\"300\" \/><\/a>C. Ray Harvey has 15 years of experience consulting with businesses on operations with a focuson designing software solutions that improve process efficiency and profitability. Prior to hiscurrent work with A\/E firms at Factor, he spent 12 years growinga professional services firm asa project manager and director of consulting services. At Factor, he has assisted hundreds ofarchitecture and engineering firms in refining processes and implementing solutions tostreamline efficiency and standardize operations<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"68eb1db0","settings":{"editor":"<p>Facilitator<\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2cf8529e","settings":{"editor":"<h2 data-pm-slice=\"1 1 []\">Fiona Johann, PMP, AEC PM | Engineering Management Institute<\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"3443b7bb","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/06\/Fiona-Headshot-2.jpg\"><img class=\"alignright wp-image-75695\" title=\"Fiona Johann, PMP, AEC PM\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/06\/Fiona-Headshot-2.jpg\" alt=\"\" width=\"300\" height=\"300\" \/><\/a><\/p>\n<p>With years of experience in higher education honing leadership skills among faculty, Fiona Johann now partners with AEC engineers to help them become outstanding project managers and leaders. Drawing on her PMP certification and extensive background in leadership development, she equips professionals with the tools and strategies needed to excel in project delivery and team management.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"100","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"3","_yoast_wpseo_content_score":"60","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}