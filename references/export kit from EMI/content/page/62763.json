ter":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"video","elType":"widget"},{"id":"1f932f4","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2024\/03\/031224-TM-Webinar-How-to-Delegate-Effectively-Using-the-Laugh-Framework-for-AEC-Professionals.pdf\" target=\"_blank\" rel=\"noopener\">Click Here to Download the Slides<\/a><\/p>","align":"center","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"4d199222","settings":{"editor":"<h2>Decription<\/h2>","align":"left","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"63d1f522","settings":{"editor":"<p>How to Delegate Effectively Using the LAUGH Framework for AEC Professionals (PDH) AEC professionals typically start their careers in highly technical roles, constantly focusing on details. Then, one day when they become managers, they are asked to delegate the detailed work to focus on more management-related tasks like proposal writing, networking, and business development. However, it is extremely difficult to break old habits and delegate the work they have come to enjoy, making the failure to delegate effectively one of the biggest challenges for engineering professionals. They think, \"It will be quicker if I do it myself.\" Overcoming this challenge will help you transition from a good manager to a great one.<\/p>\n<p>In this session, you will be given a framework with an easy-to-remember ACRONYM that will allow you to facilitate simple, effective delegation.<\/p>\n<p><strong>This session will:<\/strong><\/p>\n<ol>\n<li data-list-indent=\"1\" data-list-type=\"bulleted\">Help you learn to let go of the details as a manager,<\/li>\n<li data-list-indent=\"1\" data-list-type=\"bulleted\">Provide strategies for breaking up tasks into smaller achievable ones that are easier to delegate,<\/li>\n<li data-list-indent=\"1\" data-list-type=\"bulleted\">Help you to be able to communicate your expectations clearly,<\/li>\n<li data-list-indent=\"1\" data-list-type=\"bulleted\">Give recommendations for gauging the progress of your direct reports, and<\/li>\n<li data-list-indent=\"1\" data-list-type=\"bulleted\">Discuss the importance of supporting staff on the tasks you give them and also asking for feedback on your efforts.<\/li>\n<\/ol>\n<p><em><strong>Feedback needed:<\/strong><\/em>\u00a0We ask that you please leave feedback on the session by\u00a0<a href=\"https:\/\/www.surveymonkey.com\/r\/TMDelegate31424\" target=\"_blank\" rel=\"noopener\">clicking this link<\/a><\/p>\n<p>*PDH Credits will be processed on April 2nd. Please complete the survey by April 1st th to qualify for PDH credits.<\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas","hide_title":"yes"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"2","_yoast_wpseo_content_score":"90","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}