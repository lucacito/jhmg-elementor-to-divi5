on":"top,bottom","typography_font_weight":"bold","typography_text_transform":"uppercase","_margin":{"unit":"px","top":"10","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"button","elType":"widget"},{"id":"1fbba197","settings":{"editor":"<p><span style=\"font-weight: 400;\">Most AEC professionals want to become effective project managers, and having a <\/span>PM certification <span style=\"font-weight: 400;\">is one of the best ways to prove your credibility and leadership potential.<\/span><\/p><p><span style=\"font-weight: 400;\">The challenge? Until now, most project management programs were built for generic industries, using terminology and case studies that don\u2019t reflect the reality of <\/span>engineering and construction projects<span style=\"font-weight: 400;\">.<\/span><\/p><p><b>That\u2019s why the Engineering Management Institute (EMI) created the Project Management Accelerator with AEC PM Certification \u2014 a self-paced, five-hour program built entirely around AEC-specific\u00a0project challenges.<\/b><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"798b9836","settings":{"editor":"<p><span style=\"font-weight: 400;\">Here\u2019s how it works:<\/span><\/p><ul><li aria-level=\"1\"><b style=\"font-weight: 400;\">Enroll today<\/b><span style=\"font-weight: 400;\"> and gain access to <\/span>five one-hour sessions covering the essentials of project management; from transitioning into a PM role to project scoping, budgeting, scheduling, communication, and closeout. A brief assignment will be provided after every session.<\/li><li style=\"font-weight: 400;\" aria-level=\"1\"><span style=\"font-weight: 400;\">After completing the course, you\u2019ll take a <\/span><b>25-question certification exam<\/b><span style=\"font-weight: 400;\"> to earn your official <br \/><\/span><b>AEC PM Certification<\/b><span style=\"font-weight: 400;\">.<\/span><\/li><\/ul><div>\u00a0<\/div><p><span style=\"font-weight: 400;\">Once certified, you\u2019ll unlock <\/span><b>two full years<\/b><span style=\"font-weight: 400;\"> of <\/span><b>AEC PM Assist<\/b><span style=\"font-weight: 400;\">, your ongoing project management support system that includes:<\/span><span style=\"font-weight: 400;\"><br \/><\/span><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"5d373414","settings":{"editor":"<table dir=\"ltr\" border=\"1\" cellspacing=\"0\" cellpadding=\"0\" data-sheets-root=\"1\" data-sheets-baot=\"1\"><colgroup> <col width=\"10\" \/> <col width=\"100\" \/><\/colgroup><tbody><tr><td><span style=\"font-weight: 400;\">\u2705 <\/span><b>PM Assist Micro<\/b><\/td><td><div><div><span style=\"font-weight: 400;\">40 bite-sized videos over two years that reinforce key PM concepts.<\/span><span style=\"font-weight: 400;\"><br \/><\/span><\/div><\/div><\/td><\/tr><tr><td><span style=\"font-weight: 400;\">\u2705 <\/span><b>PM Assist Live<\/b><\/td><td><div><div><strong><span style=\"font-weight: 400;\">Quarterly webinars with industry experts on topics like <\/span><b>AI in project management, risk management<\/b><span style=\"font-weight: 400;\">, and more (8 PDH credits total).<\/span><span style=\"font-weight: 400;\"><br \/><\/span><\/strong><\/div><\/div><\/td><\/tr><\/tbody><\/table>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner