ition":"top,bottom"},"elements":[],"isInner":false,"widgetType":"video","elType":"widget"},{"id":"69d524a3","settings":{"editor":"<p><span style=\"color: #ffffff;\"><a style=\"color: #ffffff;\" href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2024\/06\/052824-CTDOT-Webinar-Time-Management-and-Maximizing-Productivity-for-AEC-Professionals.pdf\" target=\"_blank\" rel=\"noopener\">Click Here to Download the Slides<\/a><\/span><\/p>","align":"center","text_color":"#FFFFFF","typography_typography":"custom","typography_font_weight":"600","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"},{"id":"5f99f7f1","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","margin":{"unit":"px","top":"0","right":0,"bottom":"50","left":0,"isLinked":false},"pa_condition_repeater":[]},"elements":[{"id":"60ed7934","settings":{"_column_size":100,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"7896b995","settings":{"editor":"<p class=\"p1\">It is becoming nearly impossible in today\u2019s world to focus intently on any one thing and therefore, the professionals that can do that will be at the top of their industry. The ability to be an effective project manager without the ability to focus and be productive is not realistic. As a project manager, you will be pulled in many different directions, and therefore you will need to learn how to handle all of the distractions and correspondence required by your job, but still allow time for intensive focus on things that will drive the most success for you and your organization.<\/p><p class=\"p1\">In this session, you will be given a blueprint for increasing your productivity on a day-to-day basis by doing things like task batching, developing most important tasks (MITs), and learning how to recognize high leverage tasks. If you can\u2019t be productive and focused on the right tasks, you will not be an effective project manager; but if you can, you will be ahead of the game.<\/p><p data-pm-slice=\"1 1 []\"><strong>In this session, you will:<\/strong><\/p><ol class=\"ProsemirrorEditor-list\"><li class=\"ProsemirrorEditor-listItem\" data-list-indent=\"1\" data-list-type=\"bulleted\"><p data-pm-slice=\"1 1 []\">Learn the 80\/20 principle and how to apply it in your career and personal life,<\/p><\/li><li class=\"ProsemirrorEditor-listItem\" data-list-indent=\"1\" data-list-type=\"bulleted\"><p data-pm-slice=\"1 1 []\">Create a daily routine that will increase productivity dramatically,<\/p><\/li><li class=\"ProsemirrorEditor-listItem\" data-list-indent=\"1\" data-list-type=\"bulleted\"><p data-pm-slice=\"1 1 []\">Apply techniques that will increase your focus throughout the day and<\/p><\/li><li class=\"ProsemirrorEditor-listItem\" data-list-indent=\"1\" data-list-type=\"bulleted\"><p data-pm-slice=\"1 1 []\">Understand the relationship between billability and productivity.<\/p><\/li><\/ol>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"2","_yoast_wpseo_content_score":"30","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}