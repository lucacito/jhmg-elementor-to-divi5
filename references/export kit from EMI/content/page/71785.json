osition":"top,bottom"},"elements":[],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"3a5bce35","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[]},"elements":[{"id":"40dadedc","settings":{"_column_size":100,"_inline_size":null,"space_between_widgets":0,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"53f2c0ac","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"64cb3505","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/01\/Tampa-Bay-Rays.jpg\"><img class=\"alignright wp-image-71845\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2025\/01\/Tampa-Bay-Rays.jpg\" alt=\"Tampa Bay Rays\" width=\"400\" height=\"267\" \/><\/a><span style=\"font-weight: 400;\">All AEC firms want to grow rapidly and acquire more market share. The problem, however, is that recruiting and retaining talent is more difficult than ever. At EMI, we look for business success that can be applied within AEC firms. The Major League Baseball team the Tampa Bay Rays have been wildly successful for years while having much less money to spend than other teams. EMI has studied the success of this organization and has distilled it into 7 actions that AEC firms can take to grow the right way.<\/span><\/p><p><span style=\"font-weight: 400;\">This complimentary webinar will give you a recipe for recruiting, developing, and retaining professionals better than other firms. Failure to join us may set your firm\u2019s growth back years.<\/span><\/p><p><span style=\"font-weight: 400;\">Seats are limited. Register today and start implementing these winning strategies immediately!<\/span><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"},{"id":"64288281","settings":{"editor":"<p class=\"fl-heading\"><b>Your Presenter<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"67d94e62","settings":{"editor":"<h2 class=\"fl-heading\"><b>Anthony Fasano, P.E., AEC PM | Engineering Management Institute<\/b><\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"13661ebd","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"alignright wp-image-55130 size-medium\" title=\"Anthony Fasano, P.E., AEC PM\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano-300x300.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a><\/p><p><span style=\"font-weight: 400;\">Most AEC organizations are too busy to focus on attracting, developing, and retaining talented professionals, making it hard to grow. Through his work a tEMI, Fasano utilizes a proven framework to help organizations, both public and private, build professional development plans, programs, and tools that help them attract, build, AND maintain strong teams and grow sustainably.<\/span><\/p><p><span style=\"font-weight: 400;\">Fasano has written a bestselling book entitled <\/span><b><i>Engineer Your Own Success <\/i><\/b><i><span style=\"font-weight: 400;\">(by IEEE-Wiley Press)<\/span><\/i><span style=\"font-weight: 400;\">, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/span><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_content_score":"90","be_title_toggle_hide":"1","_yoast_wpseo_estimated-reading-time-minutes":"2","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}