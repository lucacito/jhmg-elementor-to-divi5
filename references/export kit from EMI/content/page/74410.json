tion_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_border_border":"dashed","_border_width":{"unit":"px","top":"5","right":"5","bottom":"5","left":"5","isLinked":true},"_border_color":"#E5B74B","_border_radius":{"unit":"px","top":"20","right":"20","bottom":"20","left":"20","isLinked":true}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"42db8cd3","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/webinars-2\/\" target=\"_blank\" rel=\"noopener\">CLICK HERE<\/a>\u00a0to view all of our upcoming live events.<\/p>","align":"center","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"},{"id":"60c161dc","settings":{"_column_size":50,"_inline_size":null,"content_position":"center","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"237e9635","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"29fe06ae","settings":{"editor":"<p>In the fast-paced world of architecture, engineering, and construction (AEC), technical expertise alone isn\u2019t enough to ensure project success. This practical and thought-provoking webinar, featuring Noelle Cochran, Vice President and Risk Management Director at AECOM, will dive into the often-overlooked but mission-critical area of risk management.<\/p><p>Attendees will explore how to proactively identify, assess, and mitigate risk at every phase of a project\u2014from proposal development and contract negotiation to execution and client relations. Using real-world examples and lessons learned, Noelle will share actionable insights for engineers and project managers who want to deliver better results, minimize exposure, and grow as confident leaders in their firms.<\/p><p>Whether you're early in your project management journey or stepping into leadership, this session will help you sharpen your risk lens and lead projects with greater strategy and resilience.<\/p><p><!-- \/wp:fl-builder\/layout --><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"},{"id":"505e1d3a","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[]},"elements":[{"id":"6b252565","settings":{"_column_size":100,"_inline_size":null,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"58c1be6e","settings":{"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","pa_condition_repeater":[]},"elements":[{"id":"6df5046f","settings":{"_column_size":100,"_inline_size":null,"space_between_widgets":0,"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[{"id":"305c5b96","settings":{"editor":"<p><strong>Learning Objectives:<\/strong><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"37db4c6e","settings":{"editor":"<p>By the end of this webinar, participants will be able to:<\/p><ol><li><strong>Identify and categorize<\/strong> key types of risk in AEC projects, including technical, contractual, financial, and reputational.<\/li><li><strong>Analyze client fit and contract red flags<\/strong> to prevent future project complications and financial exposure.<\/li><li><strong>Apply risk management strategies<\/strong> throughout the full project lifecycle\u2014from planning and proposal to execution and closeout.<\/li><li><strong>Communicate and collaborate effectively<\/strong> with project teams to build a culture of shared responsibility around risk.<\/li><li><strong>Develop a personalized action plan<\/strong> for upskilling in financial and contractual project areas to advance their career trajectory.<\/li><\/ol><p><!-- \/wp:fl-builder\/layout --><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"701ec58","settings":{"editor":"<p class=\"fl-heading\"><b>Your Speaker<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"1cda340a","settings":{"editor":"<h3>About Noelle Cochran, P.E.<\/h3>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"e72739f","settings":{"editor":"<p data-pm-slice=\"1 1 []\"><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2024\/09\/Noelle-Cochran-E2-300x300-1.jpg\" target=\"_blank\" rel=\"noopener\"><img class=\"alignright wp-image-65939 size-full\" title=\"Noelle Cochran, P.E.\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2024\/09\/Noelle-Cochran-E2-300x300-1.jpg\" alt=\"AECOM\" width=\"300\" height=\"300\" \/><\/a><\/p><p>Noelle Cochran, P.E., is a vice president and risk management director at AECOM. In that role, she supports multiple business lines in identifying and managing project risk. During her lengthy consulting engineering career, Noelle has held various engineering and management positions and has led quality, risk, and technical practice programs. Noelle was introduced to engineering risk management early in her career and benefitted greatly by applying it to her project and management work. She values sharing that risk management knowledge with others to help them improve their project delivery, client service, and business operations. Noelle is an active member of the American Society of Civil Engineers (ASCE), the National Society of Professional Engineers (NSPE), and the American Council of Engineering Companies (ACEC). She currently volunteers on the ACEC Risk Management Committee and the NSPE Risk Management Task Force.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2e91e9c5","settings":{"editor":"<p class=\"fl-heading\"><b>Your Host<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"5e7c24f9","settings":{"editor":"<h3 class=\"fl-heading\">Anthony Fasano, P.E., AEC PM | Engineering Management Institute<\/h3>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"7483723f","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"alignright wp-image-55130 size-medium\" title=\"Anthony Fasano, P.E., AEC PM\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano-300x300.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a><\/p><p><span style=\"font-weight: 400;\">Most AEC organizations are too busy to focus on attracting, developing, and retaining talented professionals, making it hard to grow. Through his work at EMI, Fasano utilizes a proven framework to help organizations, both public and private, build professional development plans, programs, and tools that help them attract, build, AND maintain strong teams and grow sustainably.<\/span><\/p><p><span style=\"font-weight: 400;\">Fasano has written a bestselling book entitled <\/span><b><i>Engineer Your Own Success <\/i><\/b><i><span style=\"font-weight: 400;\">(by IEEE-Wiley Press)<\/span><\/i><span style=\"font-weight: 400;\">, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/span><\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"4","_yoast_wpseo_content_score":"60","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}