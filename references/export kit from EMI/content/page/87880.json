inked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"2428f7b0","settings":{"editor":"<p class=\"fl-heading\"><span class=\"fl-heading-text\">Summary<\/span><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"43de2532","settings":{"editor":"<p data-start=\"12\" data-end=\"199\">The AEC industry is evolving rapidly \u2014 shaped by increasing project complexity, accelerating AI adoption, workforce burnout, and changing expectations around leadership and career growth.<\/p>\n<p data-start=\"201\" data-end=\"416\">In this webinar, we explore key findings from the 2026 Future of Work in AEC Report, based on insights from 400+ AEC professionals across multiple career stages and disciplines.<\/p>\n<p data-start=\"418\" data-end=\"671\">The session introduces the \u201cThree C\u2019s\u201d framework \u2014 Clarity, Confidence, and Connection \u2014 along with a fourth reinforcing element: Ownership. Together, these pillars reveal what separates high-engagement, talent-first firms from the rest of the industry.<\/p>\n<p data-start=\"673\" data-end=\"923\">You\u2019ll learn where firms are struggling to keep pace, why traditional development systems are no longer enough, and how leading organizations are building cultures that improve engagement, retention, leadership development, and long-term performance.<\/p>\n<p data-pm-slice=\"1 1 []\"><strong>What You'll Learn:<\/strong><\/p>\n<ol>\n<li>Why career clarity and transparent advancement systems directly impact retention and performance<\/li>\n<li>How firms can build confidence in AI adoption through training, role-based learning, and repeatable workflows<\/li>\n<li>The growing disconnect between leadership and staff experiences \u2014 and how connection improves engagement<\/li>\n<li>Why ownership and employee investment create stronger accountability, initiative, and retention<\/li>\n<li>Practical strategies AEC leaders can implement this quarter to build stronger, more engaged teams in a changing industry<\/li>\n<\/ol>\n<p><!-- \/wp:fl-builder\/layout --><\/p>","pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"4d083b0a","settings":{"editor":"<p class=\"fl-heading\"><b>Speakers<\/b><\/p>","typography_typography":"custom","typography_font_size":{"unit":"px","size":30,"sizes":[]},"typography_font_weight":"700","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"30","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom","__globals__":{"text_color":"globals\/colors?id=primary"}},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"574f9f72","settings":{"editor":"<h2 class=\"fl-heading\"><b>Anthony Fasano, P.E., AEC PM | Engineering Management Institute<\/b><\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"139ab3d3","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\"><img class=\"alignright wp-image-55130\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2023\/01\/Anthony-Fasano.jpg\" alt=\"EMI- Your Engineering Career\" width=\"300\" height=\"300\" \/><\/a><\/p>\n<p>Most AEC organizations are too busy to focus on attracting, developing, and retaining talented professionals, making it hard to grow. Through his work a tEMI, Fasano utilizes a proven framework to help organizations, both public and private, build professional development plans, programs, and tools that help them attract, build, AND maintain strong teams and grow sustainably.<\/p>\n<p>Fasano has written a bestselling book entitled\u00a0<b><i>Engineer Your Own Success\u00a0<\/i><\/b><i>(by IEEE-Wiley Press) and <strong>Beyond PM Training<\/strong><\/i>, and under his stewardship, EMI has built a massive content platform including 10 active podcasts, 3 YouTube channels, and a popular blog dedicated to helping AEC professionals become better managers and leaders.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"6e5bb318","settings":{"editor":"<h2 class=\"fl-heading\">Fiona Johann, PMP, ACE PM | Engineering Management Institute<\/h2>","_margin":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"_padding":{"unit":"px","top":"0","right":"0","bottom":"0","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"},{"id":"4008ed2f","settings":{"editor":"<p><a href=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2026\/04\/fiona-headshot-2.jpg\"><img class=\"wp-image-87244 size-medium alignright\" src=\"https:\/\/engineeringmanagementinstitute.org\/wp-content\/uploads\/2026\/04\/fiona-headshot-2-300x300.jpg\" alt=\"\" width=\"300\" height=\"300\" \/><\/a><\/p>\n<p>Fiona Johann is a PMP-certified Project Manager and the Manager of Strategic Marketing &amp; Engagement at the Engineering Management Institute. With a background in higher education leadership development, she specializes in helping AEC professionals strengthen their project management, communication, and leadership capabilities in an industry undergoing rapid transformation.<\/p>\n<p>Through her work at EMI, Fiona partners with engineers, project managers, and firm leaders to develop practical leadership systems that improve team performance, engagement, and long-term career growth. Her expertise includes strategic initiatives, professional development programming, stakeholder engagement, and workforce readiness.<\/p>","_padding":{"unit":"px","top":"0","right":"0","bottom":"50","left":"0","isLinked":false},"pa_condition_repeater":[],"premium_tooltip_text":"Hi, I'm a global tooltip.","premium_tooltip_position":"top,bottom"},"elements":[],"isInner":false,"widgetType":"text-editor","elType":"widget"}],"isInner":true,"elType":"column"}],"isInner":true,"elType":"section"}],"isInner":false,"elType":"column"}],"isInner":false,"elType":"section"}],"settings":{"template":"elementor_canvas"},"metadata":{"_yoast_wpseo_estimated-reading-time-minutes":"3","_yoast_wpseo_content_score":"60","be_title_toggle_hide":"1","disable_sitewide_popup":"a:1:{i:0;s:4:\"true\";}","_yoast_wpseo_wordproof_timestamp":"","_yoast_wpseo_meta-robots-noindex":"1","_yoast_wpseo_meta-robots-nofollow":"1"}}