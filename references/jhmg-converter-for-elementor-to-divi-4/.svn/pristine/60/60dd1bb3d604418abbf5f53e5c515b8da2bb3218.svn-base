if (!defined('ABSPATH')) {
    exit; // Exit if accessed directly.
}

// Define plugin constants
define('JHMGCED_PLUGIN_PATH', plugin_dir_path(__FILE__));
define('JHMGCED_PLUGIN_URL', plugin_dir_url(__FILE__));
define('JHMGCED_VERSION', '1.0');

/**
 * Custom debug logging function that only logs when WP_DEBUG is enabled
 *
 * @param string $message The message to log
 * @param mixed $data Optional data to include in the log
 * @param string $level Log level: 'debug', 'info', 'warning', or 'error'
 */
function jhmgced_log($message, $data = null, $level = 'debug') {
    // Only log if debugging is enabled
    if (!defined('WP_DEBUG') || !WP_DEBUG) {
        return;
    }
    
    $log_prefix = 'JHMGCED: ';
    
    // Format level
    switch ($level) {
        case 'error':
            $log_prefix .= '[ERROR] ';
            break;
        case 'warning':
            $log_prefix .= '[WARNING] ';
            break;
        case 'info':
            $log_prefix .= '[INFO] ';
            break;
        default:
            $log_prefix .= '[DEBUG] ';
    }
    
    // Format data if provided
    $data_string = '';
    if ($data !== null) {
        if (is_array($data) || is_object($data)) {
            // phpcs:ignore WordPress.PHP.DevelopmentFunctions.error_log_var_export
            $data_string = ' Data: ' . var_export($data, true);
        } else {
            $data_string = ' Data: ' . $data;
        }
    }
    
    // Use WordPress debug log if available
    if (defined('WP_DEBUG') && WP_DEBUG) {
        // phpcs:ignore WordPress.PHP.DevelopmentFunctions.error_log_error_log
        error_log($log_prefix . $message . $data_string);
    }
}

// Create necessary directories on activation
register_activation_hook(__FILE__, 'jhmgced_plugin_activation');

/**
 * Plugin activation function
 */
function jhmgced_plugin_activation() {
    // Create uploads directory for the plugin if needed
    $upload_dir = wp_upload_dir();
    $plugin_upload_dir = $upload_dir['basedir'] . '/jhmgced-files';
    
    if (!file_exists($plugin_upload_dir)) {
        wp_mkdir_p($plugin_upload_dir);
        // Create an index.php file to prevent directory listing
        $index_file = $plugin_upload_dir . '/index.php';
        if (!file_exists($index_file)) {
            // Better approach using WP_Filesystem:
            global $wp_filesystem;
            if (empty($wp_filesystem)) {
                require_once ABSPATH . '/wp-admin/includes/file.php';
                WP_Filesystem();
            }

            $wp_filesystem->put_contents($index_file, '<?php // Silence is golden', FS_CHMOD_FILE);
        }
    }
    
    // Create a plugin option to store setup info
    $options = array(
        'installed_version' => JHMGCED_VERSION,
        'install_date' => current_time('mysql'),
        'uploads_dir' => $plugin_upload_dir
    );
    
    update_option('jhmgced_settings', $options);
}

/**
 * Register script and styles the WordPress way
 */
function jhmgced_register_assets() {
    // Admin styles
    wp_register_style(
        'jhmgced-admin-style',
        JHMGCED_PLUGIN_URL . 'assets/css/admin-style.css',
        array(),
        JHMGCED_VERSION
    );
    
    // Admin scripts
    wp_register_script(
        'jhmgced-admin-script',
        JHMGCED_PLUGIN_URL . 'assets/js/admin-script.js',
        array('jquery'),
        JHMGCED_VERSION,
        true
    );
    
    // Localize script for AJAX
    wp_localize_script('jhmgced-admin-script', 'jhmgced_ajax', array(
        'ajax_url' => admin_url('admin-ajax.php'),
        'nonce' => wp_create_nonce('jhmgced_ajax_nonce'),
        'i18n' => array(
            'select_page' => esc_html__('Please select a page to export.', 'jhmg-converter-for-elementor-to-divi'),
            'exporting' => esc_html__('Exporting...', 'jhmg-converter-for-elementor-to-divi')
        )
    ));
}
add_action('admin_init', 'jhmgced_register_assets');

// Include necessary files
require_once JHMGCED_PLUGIN_PATH . 'includes/functions.php';
require_once JHMGCED_PLUGIN_PATH . 'includes/mapping.php';
require_once JHMGCED_PLUGIN_PATH . 'includes/admin.php';
require_once JHMGCED_PLUGIN_PATH . 'includes/export.php';